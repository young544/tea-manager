rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: harvests
    // Document ID: auto-generated
    // Fields:
    //   - workerName: string (required, 1-100 chars)
    //   - bags: list of maps (required, max 100 items)
    //   - totalKg: number (required, positive)
    //   - ratePerKg: number (required, positive)
    //   - totalPay: number (required, positive)
    //   - date: string (required, ISO 8601)
    //   - timestamp: int (required)
    //   - status: string (required, 'paid' or 'unpaid')
    //   - uid: string (required, matches auth.uid)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidHarvest(data) {
      return hasRequiredFields(['workerName', 'bags', 'totalKg', 'ratePerKg', 'totalPay', 'date', 'timestamp', 'status', 'uid']) &&
             hasOnlyAllowedFields(['workerName', 'bags', 'totalKg', 'ratePerKg', 'totalPay', 'date', 'timestamp', 'status', 'uid']) &&
             data.workerName is string && data.workerName.size() >= 1 && data.workerName.size() <= 100 &&
             data.bags is list && data.bags.size() <= 100 &&
             data.totalKg is number && data.totalKg >= 0 &&
             data.ratePerKg is number && data.ratePerKg >= 0 &&
             data.totalPay is number && data.totalPay >= 0 &&
             data.date is string &&
             data.timestamp is int &&
             data.status in ['paid', 'unpaid'] &&
             data.uid is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /harvests/{harvestId} {
      allow read: if isAuthenticated() && isDocOwner();
      allow create: if isAuthenticated() && isValidHarvest(request.resource.data) && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && isDocOwner() && isValidHarvest(request.resource.data) && uidNotModified();
      allow delete: if isAuthenticated() && isDocOwner();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
